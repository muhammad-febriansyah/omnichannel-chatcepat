# =============================================================================
# ChatCepat — .env PRODUKSI (template)
# -----------------------------------------------------------------------------
# Cara pakai di VPS:
#   1. cp .env.production.example .env
#   2. Isi semua nilai CHANGE_ME_* (terutama secret).
#   3. docker compose -f docker-compose.prod.yml up -d --build
#
# Catatan:
#   - Host DB/Redis = nama service di docker-compose (postgres, redis), BUKAN localhost.
#   - SEMUA service membaca file .env ini (compose: env_file: .env).
#   - NEXT_PUBLIC_* di-bake saat build image web → ganti = wajib rebuild web.
#   - Generate secret: openssl rand -hex 32   (atau -base64 32 untuk kunci AES).
# =============================================================================

# --- Postgres (dipakai container postgres + URL di bawah) -------------------
POSTGRES_USER=chatcepat
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=chatcepat

# --- Database + Redis (host = service Docker) -------------------------------
# Samakan user:password:db dengan tiga baris POSTGRES_* di atas.
DATABASE_URL=postgresql+asyncpg://chatcepat:CHANGE_ME_db_password@postgres:5432/chatcepat   # engine (async)
DATABASE_URL_SYNC=postgresql://chatcepat:CHANGE_ME_db_password@postgres:5432/chatcepat       # gateway(whatsmeow) + web(drizzle)
REDIS_URL=redis://redis:6379/0                                                                # engine + gateway

# --- Auth internal web <-> engine (NILAI HARUS SAMA, satu baris cukup) -------
SERVICE_TOKEN=CHANGE_ME_service_token        # openssl rand -hex 32

# --- Enkripsi kredensial channel (AES-256-GCM) ------------------------------
# PENTING: kalau sudah ada channel terhubung, JANGAN ganti — kredensial lama
# tak bisa didekripsi. Fresh install: openssl rand -base64 32
CHANNEL_CRED_KEY=CHANGE_ME_base64_32byte

# --- Sesi & realtime --------------------------------------------------------
NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret    # openssl rand -hex 32
WS_JWT_SECRET=CHANGE_ME_ws_jwt_secret        # openssl rand -hex 32  (web+gateway harus sama)

# --- URL publik & internal --------------------------------------------------
APP_BASE_URL=https://www.chatcepat.id
ENGINE_INTERNAL_URL=http://engine:8000/internal/v1
GATEWAY_URL=http://gateway:8080
WEB_INTERNAL_URL=http://web:3000               # gateway → web: persist channels.status saat WA banned/logout
NEXT_PUBLIC_WS_URL=wss://www.chatcepat.id/ws   # samakan host dgn APP_BASE_URL (www)
UPLOAD_DIR=/data/uploads                       # mount volume persisten ke path ini
# COOKIE_DOMAIN=.chatcepat.id                  # opsional: cookie lintas www/apex
# PLATFORM_TENANT_SLUG=chatcepat               # opsional: slug tenant platform

# --- AI agent (OpenAI: chat + embedding untuk KB/RAG) -----------------------
LLM_PROVIDER=openai
LLM_API_KEY=CHANGE_ME_openai_key             # sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini              # default; dipakai provider openai
# EMBEDDING_MODEL=text-embedding-3-small     # default; dipakai KB/RAG
# LLM_MAX_TOKENS=1024
# AI_HISTORY_LIMIT=10

# --- Anti-banned WhatsApp unofficial ----------------------------------------
# Cap outbound rolling-24h per umur channel. Kosong = default 20,40,80,160,...
# Longgarin untuk volume tinggi, atau "0" untuk matikan total.
# WARMUP_DAILY_CAPS=100,200,400,800
# BROADCAST_REST_EVERY=20
# BROADCAST_REST_MIN_S=60
# BROADCAST_REST_MAX_S=180

# --- Provider channel: api.co.id (WA official / IG / FB via apico) ----------
APICO_API_KEY=CHANGE_ME_apico_key
APICO_WEBHOOK_SECRET=CHANGE_ME_apico_webhook_secret   # verify X-Webhook-Signature
# APICO_BASE_URL=https://chat.api.co.id/api/v1/public  # default; jarang diganti

# --- Telegram (Bot API) -----------------------------------------------------
# URL publik gateway. Tanpa ini, channel Telegram baru jadi "pending" (no inbound).
TELEGRAM_WEBHOOK_BASE=https://www.chatcepat.id

# --- Meta / Facebook / Instagram (OAuth + WA embedded signup) ---------------
# FB_* untuk FB/IG OAuth. META_* untuk WhatsApp Cloud embedded signup.
# Sering 1 Meta app yang sama → id & secret sama.
FB_APP_ID=2210262782822425
FB_APP_SECRET=CHANGE_ME_meta_app_secret
META_APP_ID=2210262782822425
META_APP_SECRET=CHANGE_ME_meta_app_secret
META_VERIFY_TOKEN=CHANGE_ME_verify_token       # token verify webhook Meta (bebas, samakan di Meta dashboard)
NEXT_PUBLIC_FB_APP_ID=2210262782822425         # build-time (web)
NEXT_PUBLIC_WA_CONFIG_ID=1308745857560568      # build-time (web)

# --- Pembayaran Duitku ------------------------------------------------------
DUITKU_MERCHANT_CODE=CHANGE_ME_merchant_code
DUITKU_API_KEY=CHANGE_ME_duitku_key
DUITKU_ENV=production                          # "sandbox" untuk uji coba
