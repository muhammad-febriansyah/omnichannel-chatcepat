# Catatan: JANGAN taruh komentar inline setelah nilai (mis. `FOO=bar # x`).
# docker --env-file / compose env_file memasukkan komentar ke dalam value.
# Komentar wajib di baris sendiri.

# --- shared ---
DATABASE_URL=postgresql+asyncpg://chatcepat:chatcepat@postgres:5432/chatcepat
# DATABASE_URL_SYNC dipakai alembic + whatsmeow sqlstore (lib/pq). lib/pq default
# sslmode=require → wajib eksplisit. Lokal/docker: sslmode=disable. Produksi: require/verify-full.
DATABASE_URL_SYNC=postgresql://chatcepat:chatcepat@postgres:5432/chatcepat?sslmode=disable
REDIS_URL=redis://redis:6379/0
# auth antar servis (09)
SERVICE_TOKEN=change-me

# --- engine ---
# Provider LLM (06): kosong=AI nonaktif(fallback) | echo=dev | openai | anthropic
LLM_PROVIDER=
LLM_API_KEY=
# openai chat model (default gpt-4o-mini); embedding 1536-dim cocok pgvector
OPENAI_CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- gateway ---
# verifikasi webhook Meta (04)
META_APP_SECRET=
META_VERIFY_TOKEN=
WS_JWT_SECRET=

# --- web ---
NEXTAUTH_SECRET=
# Domain cookie lintas-subdomain (prod). Contoh: .chatcepat.id . Kosong = host-only (dev).
COOKIE_DOMAIN=
# NEXT_PUBLIC_* di-bake saat build image web (lihat web/Dockerfile build args).
# Prod: wss + domain publik (mis. wss://www.chatcepat.id/ws).
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
# FB App ID (publik) — WA Embedded Signup & FB JS SDK.
NEXT_PUBLIC_FB_APP_ID=
# WhatsApp Embedded Signup config_id dari Meta.
NEXT_PUBLIC_WA_CONFIG_ID=
ENGINE_INTERNAL_URL=http://engine:8000/internal/v1
# Web (BFF) → gateway untuk proxy SSE pairing QR WA unofficial (Docker: http://gateway:8080).
GATEWAY_URL=http://gateway:8080
# Direktori upload PERSISTEN (mount volume ke path ini). Tanpa volume → file hilang tiap deploy.
UPLOAD_DIR=/data/uploads
